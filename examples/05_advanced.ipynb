   "source": [
    "## Configuration\n",
    "\n",
    "The C library exposes a configuration dictionary. Useful keys include `log_level`, `abs_tol`, `rel_tol`, `dedup`, and `export_materials`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "e12",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  abs_tol                   = 1e-14\n",
      "  dedup                     = True\n",
      "  export_materials          = True\n",
      "  export_transforms         = True\n",
      "  fill_depth                = 0\n",
      "  flatten_max_depth         = 0\n",
      "  log_level                 = 2\n",
      "  merge_cell_weight         = 1.0\n",
      "  merge_max_surfaces        = 24\n",
      "  merge_min_cells           = 1\n",
      "  merge_surface_weight      = 0.1\n",
      "  merge_use_greedy          = False\n",
      "  rel_tol                   = 1e-12\n",
      "  universe_depth            = -1\n",
      "  void_consolidate          = 100\n",
      "  void_max_depth            = 8\n",
      "  void_min_size             = 0.1\n",
      "  void_probes_per_axis      = 3\n",
      "  zero_threshold            = 1e-14\n"
     ]
    }
   ],
   "source": [
    "model = ath.Model()\n",
    "\n",
    "# Read current configuration\n",
    "cfg = model.backend.config\n",
    "for k, v in sorted(cfg.items()):\n",
    "    print(f\"  {k:25s} = {v}\")"
   ]
  },
  {
   "cell_type": "code",
