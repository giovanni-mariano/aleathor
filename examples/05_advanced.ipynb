   "source": [
    "# Advanced Features\n",
    "\n",
    "In this notebook you will learn about:\n",
    "- The surface gallery — all available surface types\n",
    "- Volume estimation via random ray tracing\n",
    "- Extracting a sub-region into a new model\n",
    "- Geometry validation and overlap detection\n",
    "- System configuration\n",
    "- Void generation — automatically finding empty space in a geometry"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "e2",
   "metadata": {},
   "outputs": [],
   "source": [
    "%matplotlib inline\n",
    "import aleathor as ath\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e3",
   "metadata": {},
   "source": [
    "## Surface gallery\n",
    "\n",
    "aleathor supports all MCNP surface types. Here we show a selection of primitives and macrobodies."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "e4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1600x800 with 8 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "surface_specs = [\n",
    "    (\"Sphere\",     ath.Sphere(0, 0, 0, radius=3)),\n",
    "    (\"ZCylinder\",  ath.ZCylinder(0, 0, radius=3)),\n",
    "    (\\"RPP\\",  ath.RPP(-3, 3, -2, 2, -4, 4)),\n",
    "    (\"RCC\",        ath.RCC(0, 0, -4, 0, 0, 8, 3)),\n",
    "    (\"TRC\",        ath.TRC(0, 0, -3, 0, 0, 6, 3, 1)),\n",
    "    (\"ZTorus\",     ath.ZTorus(0, 0, 0, major_radius=4, minor_radius=1.5)),\n",
    "    (\"ZCone\",      ath.ZCone(0, 0, 0, t_sq=0.25)),\n",
    "]\n",
    "\n",
    "fig, axes = plt.subplots(2, 4, figsize=(16, 8))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for idx, (label, surf) in enumerate(surface_specs):\n",
    "    m = ath.Model(label)\n",
    "    m.add_material(1, name=\"solid\", density=1.0)\n",
    "    outer = ath.RPP(-8, 8, -8, 8, -8, 8)\n",
    "    m.add_cell(region=-surf, material=1, density=1.0)\n",
    "    m.add_cell(region=-outer & +surf, material=0, density=0)\n",
    "    m.plot(z=0, bounds=(-6, 6, -6, 6), ax=axes[idx])\n",
    "    axes[idx].set_title(label)\n",
    "\n",
    "# Hide the unused subplot\n",
    "axes[-1].set_visible(False)\n",
    "plt.tight_layout()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e5",
   "metadata": {},
   "source": [
    "## Volume estimation\n",
    "\n",
    "`model.analysis.bounding_sphere()` finds a tight bounding sphere, then `model.analysis.estimate_cell_volumes()` uses random ray tracing inside that sphere to estimate each cell's volume."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Bounding sphere: center=(0.0, 0.0, 0.0), radius=14.0\n",
      "\n",
      "Estimated volumes (50 000 rays):\n",
      "  Cell 1 (sphere    ):    513.3 cm³  rel err=1.26%\n",
      "  Cell 2 (box_shell ):   3569.5 cm³  rel err=0.47%\n",
      "\n",
      "Exact sphere volume: 523.6 cm³\n"
     ]
    }
   ],
   "source": [
    "model = ath.Model(\"Volume test\")\n",
    "\n",
    "# Define materials\n",
    "model.add_material(1, name=\"Uranium\", density=10.0).add_element(92, 1.0)\n",
    "model.add_material(2, name=\"Steel\", density=1.0).add_element(26, 1.0)\n",
    "\n",
    "s = ath.Sphere(0, 0, 0, radius=5)\n",
    "b = ath.RPP(-8, 8, -8, 8, -8, 8)\n",
    "model.add_cell(region=-s,          material=1, density=10.0, name=\"sphere\")\n",
    "model.add_cell(region=-b & +s,     material=2, density=1.0,  name=\"box_shell\")\n",
    "\n",
    "cx, cy, cz, r = model.analysis.bounding_sphere()\n",
    "print(f\"Bounding sphere: center=({cx:.1f}, {cy:.1f}, {cz:.1f}), radius={r:.1f}\")\n",
    "\n",
    "volume_result = model.analysis.estimate_cell_volumes(n_rays=50000)\n",
    "print(f\"\\nEstimated volumes (50 000 rays):\")\n",
    "for cell, vol, rel_err in zip(model.cells, volume_result[\"volumes\"], volume_result[\"rel_errors\"]):\n",
    "    print(f\"  Cell {cell.id} ({cell.name:10s}): {vol:8.1f} cm³  rel err={rel_err:.2%}\")\n",
    "\n",
    "import math\n",
    "exact_sphere = 4/3 * math.pi * 5**3\n",
    "print(f\"\\nExact sphere volume: {exact_sphere:.1f} cm³\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "cecf8714-88de-4420-82a9-1dae3acd9ca3",
   "metadata": {},
