   "source": [
    "## Add and plot void cells\n",
    "\n",
    "The model can commit a `VoidResult` back to the geometry. Each remaining void box becomes a material-0 cell, closing gaps in the model. The plot below renders the actual updated model, not a rectangle overlay."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "add-void-cells",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Added 1 void cells\n",
      "Cells before: 2\n",
      "Cells after:  3\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 700x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "cells_before = len(model.cells)\n",
    "added = model.void.add(voids)\n",
    "\n",
    "print(f\"Added {added} void cells\")\n",
    "print(f\"Cells before: {cells_before}\")\n",
    "print(f\"Cells after:  {len(model.cells)}\")\n",
    "\n",
    "# Render the real model after void-cell insertion.\n",
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "model.plot(z=0, bounds=(-11, 11, -11, 11), ax=ax)\n",
    "ax.set_title(\"After adding void cells\")\n",
    "plt.tight_layout()"
   ]
  },
