   "source": [
    "## Extract a sub-region\n",
    "\n",
    "`extract_region(bounds)` returns a new `Model` containing only the cells whose bounding boxes intersect the given box."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "e8",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x600 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Load a larger model\n",
    "full = ath.load(\"../tests/data/shielding.inp\")\n",
    "\n",
    "# Extract a sub-region\n",
    "sub = full.extract_region((-30, 30, -30, 30, -5, 5))\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
    "full.plot(z=0, bounds=(-65, 65, -65, 65), ax=ax1)\n",
    "ax1.set_title(\"Full model\")\n",
    "sub.plot(z=0, bounds=(-30, 30, -30, 30), ax=ax2)\n",
    "ax2.set_title(\"Extracted sub-region\")\n",
    "plt.tight_layout()"
   ]
  },
  {
