   "id": "npa8rntn1en",
   "metadata": {},
   "source": [
    "## Mixtures\n",
    "\n",
    "Create homogenized materials from weighted combinations of existing materials.\n",
    "Useful for smeared regions in simplified models."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "u0z3j959jw",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fuel-clad mixture: M10\n",
      "Water-zirc mixture: M20\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x800 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "text/plain": [
       "<Axes: title={'center': 'Z = 0'}, xlabel='X', ylabel='Y'>"
      ]
     },
     "execution_count": 6,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "model = ath.Model(\"Mixture Demo\")\n",
    "\n",
    "# Define base materials\n",
    "uo2 = model.add_material(1, name=\"UO2\", density=10.97)\n",
    "uo2.add_nuclide(92235, 0.045, \"80c\")\n",
    "uo2.add_nuclide(92238, 0.955, \"80c\")\n",
    "uo2.add_element(8, 2.0)\n",
    "\n",
    "zirc = model.add_material(2, name=\"Zircaloy-4\", density=6.56)\n",
    "zirc.weight_fractions = True\n",
    "zirc.add_element(40, 0.9823)\n",
    "zirc.add_element(50, 0.0145)\n",
    "zirc.add_element(26, 0.0021)\n",
    "zirc.add_element(24, 0.0011)\n",
    "\n",
    "water = model.add_material(3, name=\"Light water\", density=0.997)\n",
    "water.add_element(1, 2.0)\n",
    "water.add_element(8, 1.0)\n",
    "\n",
    "# Create mixtures — weighted combinations of existing materials\n",
    "# 85% UO2 + 15% Zircaloy-4 (smeared fuel-clad)\n",
    "fuel_clad_id = model.create_mixture([1, 2], [0.85, 0.15],\n",
    "                                     new_id=10, name=\"UO2-Zirc mix\")\n",
    "print(f\"Fuel-clad mixture: M{fuel_clad_id}\")\n",
    "\n",
    "# 50% water + 50% Zircaloy (homogenized lattice region)\n",
    "water_zirc_id = model.create_mixture([3, 2], [0.5, 0.5],\n",
    "                                      new_id=20, name=\"Water-Zirc mix\")\n",
    "print(f\"Water-zirc mixture: M{water_zirc_id}\")\n",
    "\n",
    "# Use mixtures in cells\n",
    "sphere = ath.Sphere(0, 0, 0, radius=5)\n",
    "shell  = ath.Sphere(0, 0, 0, radius=8)\n",
    "box    = ath.RPP(-12, 12, -12, 12, -12, 12)\n",
    "\n",
    "model.add_cell(region=-sphere,              material=fuel_clad_id,  density=9.5,  name=\"fuel_region\")\n",
    "model.add_cell(region=-shell & +sphere,     material=water_zirc_id, density=3.5,  name=\"lattice_region\")\n",
    "model.add_cell(region=-box & +shell,        material=3,             density=0.997, name=\"water\")\n",
    "\n",
    "model.plot(z=0, bounds=(-12, 12, -12, 12), by_material=True, show_colorbar=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e9",
   "metadata": {},
   "source": [
